# Selection Systematic
#
# This study is now integrated into the main pipeline Snakefile (analysis/Snakefile)
# as rule `selection_systematic`.  Run from the analysis/ directory:
#
#   uv run snakemake selection_systematic -j4
#
# This standalone Snakefile is kept for reference only.
# It still works for manual debugging:
#
#   cd studies/selection_systematic
#   uv run snakemake -j4

import sys
from pathlib import Path

sys.path.insert(0, str(Path(workflow.basedir).parent.parent))

BRANCHES   = ["high_yield", "low_yield"]
CATEGORIES = ["LL", "DD"]
CONFIG_DIR = "../../config"
CACHE_DIR  = "../../analysis_output/mva/cache"
OUTPUT_DIR = "../../analysis_output/mva"

rule all:
    input:
        expand(
            "output/selection_systematics_{branch}_{category}.json",
            branch=BRANCHES,
            category=CATEGORIES,
        )

rule run_selection_systematic:
    output:
        "output/selection_systematics_{branch}_{category}.json"
    shell:
        """
        uv run python run_selection_systematic.py \
            --branch     {wildcards.branch} \
            --category   {wildcards.category} \
            --config-dir {CONFIG_DIR} \
            --cache-dir  {CACHE_DIR} \
            --output-dir output
        """
