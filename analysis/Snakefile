# Snakefile ‚ÄĒ B‚Āļ ‚Üí őõŐĄpK‚ĀĽK‚Āļ Charmonium Analysis Pipeline
#
# Usage:
#   snakemake -j1                          # Run full pipeline
#   snakemake -n                           # Dry run
#   snakemake validate_config              # Run single rule
#   snakemake --config years="[2016]"      # Override config
#   snakemake --dag | dot -Tpdf > dag.pdf  # Visualize DAG
#
# The top-level Snakefile is the authoritative DAG for active studies, the main
# analysis pipeline, systematics aggregation, and optional presentation plots.
#
# LL and DD Lambda categories are processed separately through rules 3-6
# (optimize -> apply_cuts -> mass_fitting -> efficiency_calculation). They are
# combined only at rule 7 (branching_ratios), following the reference analysis.

configfile: "snakemake_config.yaml"

from pathlib import Path

# ---------------------------------------------------------------------------
# Global configuration
# ---------------------------------------------------------------------------
CONFIG_DIR = config.get("config_dir", "config")
CACHE_DIR = config.get("cache_dir", "cache")
ROOT_OUTPUT_DIR = config.get("output_dir", "analysis_output")

YEARS = config.get("years", ["2016", "2017", "2018"])
TRACK_TYPES = config.get("track_types", ["LL", "DD"])
MAGNETS = config.get("magnets", ["MD", "MU"])
STATES = config.get("states", ["jpsi", "etac", "chic0", "chic1"])
USE_MANUAL_CUTS = config.get("use_manual_cuts", False)
NO_CACHE = config.get("no_cache", False)

# Lambda categories processed separately through optimization and fitting
CATEGORIES = TRACK_TYPES  # ["LL", "DD"]
BRANCHES = ["high_yield", "low_yield"]

from modules.config_loader import StudyConfig

# Determine optimization type (prioritize --config opt_method=... over selection.toml)
OPT_METHOD = config.get("opt_method")
study_config = StudyConfig.from_dir(CONFIG_DIR)

if not OPT_METHOD:
    try:
        OPT_METHOD = study_config.get_optimization_type()
    except Exception as e:
        selection_path = Path(CONFIG_DIR) / "selection.toml"
        print(f"Warning: Could not read {selection_path}: {e}. Defaulting to 'box'")

if not OPT_METHOD:
    OPT_METHOD = "box"

print(f"INFO: Using optimization method: {OPT_METHOD}")

# Redefine output and cache directories to be method-specific
OUTPUT_DIR = f"{ROOT_OUTPUT_DIR}/{OPT_METHOD}"
CACHE_DIR = f"{OUTPUT_DIR}/cache"

# ---------------------------------------------------------------------------
# Config file list (all TOML files in config/)
# ---------------------------------------------------------------------------
CONFIG_FILES = [
    f"{CONFIG_DIR}/{f}"
    for f in [
        "physics.toml",
        "detector.toml",
        "fitting.toml",
        "selection.toml",
        "generator_effs.toml",
        "triggers.toml",
        "data.toml",
        "efficiencies.toml",
        "paths.toml",
        "luminosity.toml",
        "branching_fractions.toml",
    ]
]

# ---------------------------------------------------------------------------
# Workflow path conventions
# ---------------------------------------------------------------------------
MVA_MODEL_PATTERN = "studies/mva_optimization/output/models/catboost_bdt_{category}.cbm"
MVA_REPORT_PATTERN = "studies/mva_optimization/output/mva_optimization_report_{category}.txt"
MVA_COMPLETED = "studies/mva_optimization/mva_optimization_completed.txt"

TRIGGER_JSON = "studies/trigger_tis_tos/output/tis_tos_results.json"
TRIGGER_TXT = "studies/trigger_tis_tos/output/tis_tos_results.txt"

KIN_WEIGHT_LL = "studies/kinematic_reweighting/output/kinematic_weights_LL.json"
KIN_WEIGHT_DD = "studies/kinematic_reweighting/output/kinematic_weights_DD.json"
KIN_WEIGHT_COMBINED = "studies/kinematic_reweighting/output/kinematic_weights.json"
KIN_WEIGHT_MAP_LL = "studies/kinematic_reweighting/output/weight_map_LL.pdf"
KIN_WEIGHT_MAP_DD = "studies/kinematic_reweighting/output/weight_map_DD.pdf"

EFFICIENCY_JSON = "studies/efficiency_steps/output/efficiencies.json"
EFFICIENCY_TABLES = "studies/efficiency_steps/output/efficiencies_tables.md"

PID_BOOTSTRAP_JSON = "studies/pid_cancellation/output/pid_bootstrap_systematics.json"
PID_BOOTSTRAP_MD = "studies/pid_cancellation/output/real_pidcalib_results.md"
PID_BOOTSTRAP_PDF = "studies/pid_cancellation/output/real_ratio_condensed_panel.pdf"
PID_BOOTSTRAP_PNG = "studies/pid_cancellation/output/real_ratio_condensed_panel.png"

NOTE_FIGS = "presentation/ana_note_plots/figs"
NOTE_CATEGORIES = ["LL", "DD"]
NOTE_STATES = ["Jpsi", "Etac", "Chic0", "Chic1"]

COLLECTED_RESULTS_DIR = "results"
HEP_REPORT_TEX = "results/final/hep_results.tex"
HEP_REPORT_TXT = "results/final/hep_results.txt"

# ---------------------------------------------------------------------------
# rule all ‚ÄĒ final targets
# ---------------------------------------------------------------------------
rule all:
    input:
        f"{OUTPUT_DIR}/.workflow_complete",

# ---------------------------------------------------------------------------
# Step 1: Config validation
# ---------------------------------------------------------------------------
rule validate_config:
    input:
        CONFIG_FILES,
    output:
        touch(f"{OUTPUT_DIR}/.config_validated"),
    params:
        config_dir=CONFIG_DIR,
        output_dir=OUTPUT_DIR,
    script:
        "scripts/validate_config.py"

# ---------------------------------------------------------------------------
# Step 2: Data/MC loading + Lambda pre-selection
# Outputs a nested dict {year: {category: array}} for data and
# {state: {category: array}} for MC, stored in the cache.
# ---------------------------------------------------------------------------
rule load_data:
    input:
        f"{OUTPUT_DIR}/.config_validated",
    output:
        touch(f"{OUTPUT_DIR}/.data_loaded"),
    params:
        years=YEARS,
        track_types=TRACK_TYPES,
        magnets=MAGNETS,
        states=STATES,
        no_cache=NO_CACHE,
        config_dir=CONFIG_DIR,
        cache_dir=CACHE_DIR,
    script:
        "scripts/load_data.py"

# ---------------------------------------------------------------------------
# Active prerequisite studies
# These are wired into the top-level DAG so the Makefile can stay a thin
# wrapper over one Snakemake workflow instead of launching nested sub-workflows.
# ---------------------------------------------------------------------------
rule study_mva:
    input:
        f"{OUTPUT_DIR}/.data_loaded",
    output:
        ll_model="studies/mva_optimization/output/models/catboost_bdt_LL.cbm",
        dd_model="studies/mva_optimization/output/models/catboost_bdt_DD.cbm",
        ll_report="studies/mva_optimization/output/mva_optimization_report_LL.txt",
        dd_report="studies/mva_optimization/output/mva_optimization_report_DD.txt",
        completed=MVA_COMPLETED,
    shell:
        """
        cd studies/mva_optimization/mva
        uv run python main.py --category both
        """


rule study_trigger:
    output:
        json=TRIGGER_JSON,
        txt=TRIGGER_TXT,
    params:
        config_dir=CONFIG_DIR,
    shell:
        """
        uv run python studies/trigger_tis_tos/tis_tos_study.py \
            --config-dir {params.config_dir} \
            --output-dir studies/trigger_tis_tos/output \
            > {output.txt}
        """


rule study_reweighting:
    output:
        ll=KIN_WEIGHT_LL,
        dd=KIN_WEIGHT_DD,
        combined=KIN_WEIGHT_COMBINED,
        map_ll=KIN_WEIGHT_MAP_LL,
        map_dd=KIN_WEIGHT_MAP_DD,
    params:
        config_dir=CONFIG_DIR,
        branch="high_yield",
    shell:
        """
        uv run python studies/kinematic_reweighting/derive_weights.py \
            --config-dir {params.config_dir} \
            --branch {params.branch}
        """


rule study_efficiency:
    input:
        tis_tos=TRIGGER_JSON,
        kin_ll=KIN_WEIGHT_LL,
        kin_dd=KIN_WEIGHT_DD,
    output:
        json=EFFICIENCY_JSON,
        tables=EFFICIENCY_TABLES,
    params:
        config_dir=CONFIG_DIR,
        mva_output_dir=f"{ROOT_OUTPUT_DIR}/mva",
        branch="high_yield",
    shell:
        """
        uv run python studies/efficiency_steps/calculate_efficiencies.py \
            --config-dir {params.config_dir} \
            --output {output.json} \
            --tis-tos {input.tis_tos} \
            --kin-weights-dir studies/kinematic_reweighting/output \
            --mva-output-dir {params.mva_output_dir} \
            --branch {params.branch}
        """


rule study_pid_bootstrap:
    output:
        json=PID_BOOTSTRAP_JSON,
        md=PID_BOOTSTRAP_MD,
        pdf=PID_BOOTSTRAP_PDF,
        png=PID_BOOTSTRAP_PNG,
    shell:
        """
        cd studies/pid_cancellation
        uv run python apply_pidcalib.py --bootstrap-n 100 --bootstrap-seed 42
        """


rule prerequisite_studies:
    input:
        MVA_COMPLETED,
        expand(MVA_MODEL_PATTERN, category=NOTE_CATEGORIES),
        TRIGGER_JSON,
        KIN_WEIGHT_LL,
        KIN_WEIGHT_DD,
        EFFICIENCY_JSON,
    output:
        f"{OUTPUT_DIR}/.studies_complete",
    shell:
        "touch {output}"


# ---------------------------------------------------------------------------
# Presentation workflows
# ---------------------------------------------------------------------------
rule plot_backgrounds:
    output:
        expand(f"{NOTE_FIGS}/Lambda{{cat}}/backgrounds/ks0_veto.pdf", cat=NOTE_CATEGORIES),
        expand(f"{NOTE_FIGS}/Lambda{{cat}}/backgrounds/nonresonant_mLpK.pdf", cat=NOTE_CATEGORIES),
        expand(f"{NOTE_FIGS}/Lambda{{cat}}/backgrounds/nonresonant_Bcorr.pdf", cat=NOTE_CATEGORIES),
        expand(f"{NOTE_FIGS}/Lambda{{cat}}/backgrounds/partial_reco.pdf", cat=NOTE_CATEGORIES),
        expand(f"{NOTE_FIGS}/Lambda{{cat}}/misID_{{cat}}_beforePID.pdf", cat=NOTE_CATEGORIES),
        expand(f"{NOTE_FIGS}/Lambda{{cat}}/misID_{{cat}}_afterPID.pdf", cat=NOTE_CATEGORIES),
    shell:
        """
        uv run python presentation/background_studies/plot_background_studies.py
        uv run python presentation/background_studies/plot_backgrounds.py
        """


rule plot_reweighting:
    input:
        KIN_WEIGHT_LL,
        KIN_WEIGHT_DD,
    output:
        expand(f"{NOTE_FIGS}/Lambda{{cat}}/reweight/reweight_Bu_PT_cmp.pdf", cat=NOTE_CATEGORIES),
    shell:
        """
        uv run python presentation/validation/plot_reweighting.py
        """


rule plot_note:
    output:
        expand(f"{NOTE_FIGS}/Lambda{{cat}}/Preselections/Delta_Z.pdf", cat=NOTE_CATEGORIES),
        expand(
            f"{NOTE_FIGS}/Lambda{{cat}}/Preselections/Bu_M_after_preselection.pdf",
            cat=NOTE_CATEGORIES,
        ),
        expand(f"{NOTE_FIGS}/Lambda{{cat}}/L0_M_after_preselection.pdf", cat=NOTE_CATEGORIES),
        expand(f"{NOTE_FIGS}/Lambda{{cat}}/logIPCHI2run2_Sig.pdf", cat=NOTE_CATEGORIES),
        expand(f"{NOTE_FIGS}/Lambda{{cat}}/bdt_variables/BDT_DTFchi2_Sig.pdf", cat=NOTE_CATEGORIES),
        expand(f"{NOTE_FIGS}/Lambda{{cat}}/bdt_variables/BDT_FDCHI2_Sig.pdf", cat=NOTE_CATEGORIES),
        expand(f"{NOTE_FIGS}/Lambda{{cat}}/bdt_variables/BDT_IPCHI2_Sig.pdf", cat=NOTE_CATEGORIES),
        expand(f"{NOTE_FIGS}/Lambda{{cat}}/bdt_variables/BDT_PT_Sig.pdf", cat=NOTE_CATEGORIES),
        expand(f"{NOTE_FIGS}/Lambda{{cat}}/pidcmp.pdf", cat=NOTE_CATEGORIES),
        expand(
            f"{NOTE_FIGS}/Lambda{{cat}}/fit/fit_To{{state}}_Run2MDU_MC.pdf",
            cat=NOTE_CATEGORIES,
            state=NOTE_STATES,
        ),
        expand(f"{NOTE_FIGS}/Lambda{{cat}}/fit/fit_todata_signal.pdf", cat=NOTE_CATEGORIES),
        expand(f"{NOTE_FIGS}/Lambda{{cat}}/fit/fit_to_sideband.pdf", cat=NOTE_CATEGORIES),
        expand(f"{NOTE_FIGS}/Lambda{{cat}}/charmonium_spectrum.pdf", cat=NOTE_CATEGORIES),
    shell:
        """
        uv run python presentation/ana_note_plots/scripts/plot_preselection.py
        uv run python presentation/ana_note_plots/scripts/plot_bdt_variables.py
        uv run python presentation/ana_note_plots/scripts/plot_pid.py
        uv run python presentation/ana_note_plots/scripts/plot_normchannel.py
        uv run python presentation/ana_note_plots/scripts/plot_mcfits.py
        uv run python presentation/ana_note_plots/scripts/plot_charmonium_spectrum.py
        uv run python presentation/ana_note_plots/scripts/plot_datafit.py
        """


rule presentation_plots:
    input:
        rules.plot_backgrounds.output,
        rules.plot_reweighting.output,
        rules.plot_note.output,
    output:
        f"{OUTPUT_DIR}/.presentation_plots_complete",
    shell:
        "touch {output}"

# ---------------------------------------------------------------------------
# Step 3: Selection optimisation ‚ÄĒ one per (branch, category)
#
# In "passthrough" mode the optimisation is skipped entirely.  A trivial
# optimized_cuts.json (opt_type = "passthrough") is written so that
# apply_cuts.py simply forwards the pre-selected events unchanged.
# ---------------------------------------------------------------------------
if OPT_METHOD == "passthrough":
    rule passthrough_selection:
        """Passthrough: skip optimisation, write trivial cuts file."""
        input:
            f"{OUTPUT_DIR}/.data_loaded",
        output:
            f"{OUTPUT_DIR}/{{branch}}/{{category}}/models/optimized_cuts.json",
        params:
            branch="{branch}",
            category="{category}",
        script:
            "scripts/passthrough_selection.py"
else:
    rule optimize_selection:
        input:
            f"{OUTPUT_DIR}/.data_loaded",
            model=MVA_MODEL_PATTERN if OPT_METHOD == "mva" else [],
        output:
            f"{OUTPUT_DIR}/{{branch}}/{{category}}/models/optimized_cuts.json",
        params:
            use_manual_cuts=USE_MANUAL_CUTS,
            no_cache=NO_CACHE,
            config_dir=CONFIG_DIR,
            cache_dir=CACHE_DIR,
            output_dir=OUTPUT_DIR,
            years=YEARS,
            category="{category}",
            branch="{branch}",
            opt_method=OPT_METHOD,
        script:
            "scripts/optimize_selection.py"

# ---------------------------------------------------------------------------
# Step 4: Apply optimized cuts ‚ÄĒ one per (branch, category)
# ---------------------------------------------------------------------------
rule apply_cuts:
    input:
        data_loaded=f"{OUTPUT_DIR}/.data_loaded",
        cuts=f"{OUTPUT_DIR}/{{branch}}/{{category}}/models/optimized_cuts.json",
    output:
        summary=f"{OUTPUT_DIR}/{{branch}}/{{category}}/tables/cut_summary.json",
    params:
        branch="{branch}",
        category="{category}",
        no_cache=NO_CACHE,
        config_dir=CONFIG_DIR,
        cache_dir=CACHE_DIR,
        output_dir=OUTPUT_DIR,
        years=YEARS,
    script:
        "scripts/apply_cuts.py"

# ---------------------------------------------------------------------------
# Step 5: Mass fitting ‚ÄĒ one per (branch, category)
# ---------------------------------------------------------------------------
rule mass_fitting:
    input:
        f"{OUTPUT_DIR}/{{branch}}/{{category}}/tables/cut_summary.json",
    output:
        f"{OUTPUT_DIR}/{{branch}}/{{category}}/tables/fitted_yields.csv",
    params:
        branch="{branch}",
        category="{category}",
        no_cache=NO_CACHE,
        config_dir=CONFIG_DIR,
        cache_dir=CACHE_DIR,
        output_dir=OUTPUT_DIR,
        opt_method=OPT_METHOD,
    script:
        "scripts/mass_fitting.py"

# ---------------------------------------------------------------------------
# Step 5b: Combined LL+DD mass fit ‚ÄĒ one per branch
# Concatenates LL and DD events per year and fits the merged sample.
# Purpose: publication-quality combined plot + cross-check yields.
# Yield extraction for branching fractions uses the separate LL/DD fits above.
# ---------------------------------------------------------------------------
rule mass_fitting_combined:
    input:
        ll=f"{OUTPUT_DIR}/{{branch}}/LL/tables/cut_summary.json",
        dd=f"{OUTPUT_DIR}/{{branch}}/DD/tables/cut_summary.json",
    output:
        f"{OUTPUT_DIR}/{{branch}}/LL_DD/tables/fitted_yields_combined.csv",
    params:
        branch="{branch}",
        no_cache=NO_CACHE,
        config_dir=CONFIG_DIR,
        cache_dir=CACHE_DIR,
        output_dir=OUTPUT_DIR,
        opt_method=OPT_METHOD,
    script:
        "scripts/mass_fitting_combined.py"

# ---------------------------------------------------------------------------
# Step 6: Efficiency calculation ‚ÄĒ one per (branch, category)
# ---------------------------------------------------------------------------
rule efficiency_calculation:
    input:
        summary=f"{OUTPUT_DIR}/{{branch}}/{{category}}/tables/cut_summary.json",
        cuts=f"{OUTPUT_DIR}/{{branch}}/{{category}}/models/optimized_cuts.json",
        study_eff=EFFICIENCY_JSON,
    output:
        efficiencies=f"{OUTPUT_DIR}/{{branch}}/{{category}}/tables/efficiencies.csv",
        ratios=f"{OUTPUT_DIR}/{{branch}}/{{category}}/tables/efficiency_ratios.csv",
    params:
        branch="{branch}",
        category="{category}",
        no_cache=NO_CACHE,
        config_dir=CONFIG_DIR,
        cache_dir=CACHE_DIR,
        output_dir=OUTPUT_DIR,
    script:
        "scripts/efficiency_calculation.py"

# ---------------------------------------------------------------------------
# Step 7: Branching fraction ratios
# Takes LL and DD fitted yields and efficiency tables as inputs.
# Yields are summed across categories before computing the ratio.
# ---------------------------------------------------------------------------
rule branching_ratios:
    input:
        yields_ll=f"{OUTPUT_DIR}/{{branch}}/LL/tables/fitted_yields.csv",
        yields_dd=f"{OUTPUT_DIR}/{{branch}}/DD/tables/fitted_yields.csv",
        efficiencies_ll=f"{OUTPUT_DIR}/{{branch}}/LL/tables/efficiencies.csv",
        efficiencies_dd=f"{OUTPUT_DIR}/{{branch}}/DD/tables/efficiencies.csv",
        ratios_ll=f"{OUTPUT_DIR}/{{branch}}/LL/tables/efficiency_ratios.csv",
        ratios_dd=f"{OUTPUT_DIR}/{{branch}}/DD/tables/efficiency_ratios.csv",
    output:
        br_ratios=f"{OUTPUT_DIR}/{{branch}}/tables/branching_fraction_ratios.csv",
        final_results=f"{OUTPUT_DIR}/{{branch}}/results/final_results.md",
    params:
        branch="{branch}",
        config_dir=CONFIG_DIR,
        cache_dir=CACHE_DIR,
        output_dir=OUTPUT_DIR,
    script:
        "scripts/branching_ratios.py"

# ---------------------------------------------------------------------------
# Step 8: Branch comparison
# ---------------------------------------------------------------------------
rule compare_branches:
    input:
        high_yield=f"{OUTPUT_DIR}/high_yield/results/final_results.md",
        low_yield=f"{OUTPUT_DIR}/low_yield/results/final_results.md",
    output:
        report=f"{OUTPUT_DIR}/comparison/branch_comparison.md",
    script:
        "scripts/compare_branches.py"

# ---------------------------------------------------------------------------
# Step 9a: Fit model systematics ‚ÄĒ one job per (branch, category)
#
# Runs 5 fit variations (resolution ¬Ī2 MeV, ARGUS endpoint ¬Ī50 MeV,
# Chebyshev background alternative) and records őīN per charmonium state.
# Depends on apply_cuts because it reads the cut-filtered data from the cache.
# ---------------------------------------------------------------------------
rule fit_systematics:
    input:
        cut_summary=f"{OUTPUT_DIR}/{{branch}}/{{category}}/tables/cut_summary.json",
    output:
        "studies/fit_systematics/output/fit_systematics_{branch}_{category}.json",
    params:
        config_dir=CONFIG_DIR,
        cache_dir=CACHE_DIR,
    shell:
        """
        uv run python studies/fit_systematics/run_fit_systematics.py \
            --branch     {wildcards.branch} \
            --category   {wildcards.category} \
            --config-dir {params.config_dir} \
            --cache-dir  {params.cache_dir} \
            --output-dir studies/fit_systematics/output
        """

# ---------------------------------------------------------------------------
# Step 9b: Selection threshold systematic ‚ÄĒ one job per (branch, category)
#
# In passthrough mode there is no threshold to vary, so the systematic is
# written as zero for all states.  In optimised modes the BDT threshold is
# shifted ¬Ī1 step and the mass fit is repeated.
# ---------------------------------------------------------------------------
if OPT_METHOD == "passthrough":
    rule passthrough_selection_systematic:
        """Passthrough: write zero selection systematic (no selection to vary)."""
        input:
            cut_summary=f"{OUTPUT_DIR}/{{branch}}/{{category}}/tables/cut_summary.json",
        output:
            "studies/selection_systematic/output/selection_systematics_{branch}_{category}.json",
        script:
            "scripts/passthrough_selection_systematic.py"
else:
    rule selection_systematic:
        input:
            cut_summary=f"{OUTPUT_DIR}/{{branch}}/{{category}}/tables/cut_summary.json",
        output:
            "studies/selection_systematic/output/selection_systematics_{branch}_{category}.json",
        params:
            config_dir=CONFIG_DIR,
            cache_dir=CACHE_DIR,
        shell:
            """
            uv run python studies/selection_systematic/run_selection_systematic.py \
                --branch     {wildcards.branch} \
                --category   {wildcards.category} \
                --config-dir {params.config_dir} \
                --cache-dir  {params.cache_dir} \
                --output-dir studies/selection_systematic/output
            """

# ---------------------------------------------------------------------------
# Step 9: Aggregate systematic uncertainties
#
# Reads fit_systematics + selection_systematic JSON outputs (now produced by
# rules 9a/9b above) and aggregates into per-state systematics tables.
# ---------------------------------------------------------------------------
rule compute_systematics:
    input:
        branching_ratios=expand(
            f"{OUTPUT_DIR}/{{branch}}/tables/branching_fraction_ratios.csv",
            branch=BRANCHES,
        ),
        fit_systs=expand(
            "studies/fit_systematics/output/fit_systematics_{branch}_{category}.json",
            branch=BRANCHES,
            category=CATEGORIES,
        ),
        sel_systs=expand(
            "studies/selection_systematic/output/selection_systematics_{branch}_{category}.json",
            branch=BRANCHES,
            category=CATEGORIES,
        ),
        pid_syst=PID_BOOTSTRAP_JSON,
    output:
        expand(f"{OUTPUT_DIR}/{{branch}}/tables/systematics.json", branch=BRANCHES),
        f"{OUTPUT_DIR}/results/systematics_summary.md",
    params:
        output_dir=OUTPUT_DIR,
        studies_dir="studies",
    shell:
        """
        uv run python scripts/compute_systematics.py \
            --branches     high_yield low_yield \
            --categories   LL DD \
            --output-dir   {params.output_dir} \
            --studies-dir  {params.studies_dir}
        """

# ---------------------------------------------------------------------------
# Step 10: Export final LaTeX tables
# ---------------------------------------------------------------------------
rule export_latex_results:
    input:
        high_yield=f"{OUTPUT_DIR}/high_yield/tables/branching_fraction_ratios.csv",
        low_yield=f"{OUTPUT_DIR}/low_yield/tables/branching_fraction_ratios.csv",
        systematics=f"{OUTPUT_DIR}/results/systematics_summary.md",
    output:
        report=f"{OUTPUT_DIR}/results/bf_products.tex",
    script:
        "scripts/export_latex_results.py"

# ---------------------------------------------------------------------------
# Step 11: Collect all results into a single organised folder
# Run:  snakemake collect_results
# ---------------------------------------------------------------------------
rule collect_results:
    """Gather every important output into results/ for easy review."""
    input:
        f"{OUTPUT_DIR}/results/bf_products.tex",
        f"{OUTPUT_DIR}/results/systematics_summary.md",
        f"{OUTPUT_DIR}/comparison/branch_comparison.md",
    output:
        final_bf="results/final/bf_products.tex",
        final_syst_summary="results/final/systematics_summary.md",
        final_branch_comparison="results/final/branch_comparison.md",
        final_high_results="results/final/final_results_high_yield.md",
        final_low_results="results/final/final_results_low_yield.md",
        table_high="results/tables/branching_fraction_ratios_high_yield.csv",
        table_low="results/tables/branching_fraction_ratios_low_yield.csv",
        syst_high="results/tables/systematics_high_yield.json",
        syst_low="results/tables/systematics_low_yield.json",
        table_syst_summary="results/tables/systematics_summary.md",
    params:
        pipeline_dir=OUTPUT_DIR,
        studies_dir="studies",
        output_dir=COLLECTED_RESULTS_DIR,
    shell:
        """
        uv run python scripts/collect_results.py \
            --pipeline-dir {params.pipeline_dir} \
            --studies-dir  {params.studies_dir} \
            --output-dir   {params.output_dir}
        """

# ---------------------------------------------------------------------------
# Reporting and aggregate workflow targets
# ---------------------------------------------------------------------------
rule report_hep:
    input:
        "results/tables/branching_fraction_ratios_high_yield.csv",
        "results/tables/branching_fraction_ratios_low_yield.csv",
        "results/tables/systematics_high_yield.json",
        "results/tables/systematics_low_yield.json",
    output:
        HEP_REPORT_TEX,
        HEP_REPORT_TXT,
    params:
        results_dir=COLLECTED_RESULTS_DIR,
        output_dir="results/final",
    shell:
        """
        uv run python scripts/generate_hep_report.py \
            --results-dir {params.results_dir} \
            --output-dir  {params.output_dir}
        """


rule main_pipeline:
    input:
        expand(
            f"{OUTPUT_DIR}/{{branch}}/tables/branching_fraction_ratios.csv",
            branch=BRANCHES,
        ),
        expand(
            f"{OUTPUT_DIR}/{{branch}}/LL_DD/tables/fitted_yields_combined.csv",
            branch=BRANCHES,
        ),
        f"{OUTPUT_DIR}/comparison/branch_comparison.md",
    output:
        f"{OUTPUT_DIR}/.main_pipeline_complete",
    shell:
        "touch {output}"


rule systematics_workflow:
    input:
        PID_BOOTSTRAP_JSON,
        f"{OUTPUT_DIR}/results/systematics_summary.md",
        f"{OUTPUT_DIR}/results/bf_products.tex",
    output:
        f"{OUTPUT_DIR}/.systematics_complete",
    shell:
        "touch {output}"


rule reports:
    input:
        rules.collect_results.output,
        HEP_REPORT_TEX,
        HEP_REPORT_TXT,
    output:
        f"{OUTPUT_DIR}/.reports_complete",
    shell:
        "touch {output}"


rule full_analysis:
    input:
        f"{OUTPUT_DIR}/.studies_complete",
        f"{OUTPUT_DIR}/.main_pipeline_complete",
        f"{OUTPUT_DIR}/.systematics_complete",
        f"{OUTPUT_DIR}/.reports_complete",
    output:
        f"{OUTPUT_DIR}/.workflow_complete",
    shell:
        "touch {output}"

# ===========================================================================
# Convenience targets
# ===========================================================================
rule clean_cache:
    """Remove cached intermediate results (pickle files)."""
    shell:
        "rm -rf {CACHE_DIR}/data/*.pkl {CACHE_DIR}/metadata/*.json"

rule clean_outputs:
    """Remove output files (tables, plots, results)."""
    shell:
        "rm -rf {OUTPUT_DIR}"

rule clean_all:
    """Remove everything (cache + outputs)."""
    shell:
        "rm -rf {CACHE_DIR}/data/*.pkl {CACHE_DIR}/metadata/*.json {OUTPUT_DIR}"
