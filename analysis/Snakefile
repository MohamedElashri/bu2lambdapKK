# Snakefile ‚ÄĒ B‚Āļ ‚Üí őõŐĄpK‚ĀĽK‚Āļ Charmonium Analysis Pipeline
#
# Usage:
#   snakemake -j1                          # Run full pipeline
#   snakemake -n                           # Dry run
#   snakemake validate_config              # Run single rule
#   snakemake --config years="[2016]"      # Override config
#   snakemake --dag | dot -Tpdf > dag.pdf  # Visualize DAG
#
# Standalone studies live in analysis/studies/<study_name>/ with their own Snakefiles.
#
# Phase 1 change: LL and DD Lambda categories are now processed separately through
# rules 3‚Äď6 (optimize ‚Üí apply_cuts ‚Üí mass_fitting ‚Üí efficiency_calculation).
# They are combined only at rule 7 (branching_ratios), following the reference analysis.

configfile: "snakemake_config.yaml"

# ---------------------------------------------------------------------------
# Global configuration
# ---------------------------------------------------------------------------
CONFIG_DIR = config.get("config_dir", "config")
CACHE_DIR = config.get("cache_dir", "cache")
ROOT_OUTPUT_DIR = config.get("output_dir", "analysis_output")

YEARS = config.get("years", ["2016", "2017", "2018"])
TRACK_TYPES = config.get("track_types", ["LL", "DD"])
MAGNETS = config.get("magnets", ["MD", "MU"])
STATES = config.get("states", ["jpsi", "etac", "chic0", "chic1"])
USE_MANUAL_CUTS = config.get("use_manual_cuts", False)
NO_CACHE = config.get("no_cache", False)

# Lambda categories processed separately through optimization and fitting
CATEGORIES = TRACK_TYPES  # ["LL", "DD"]
BRANCHES = ["high_yield", "low_yield"]

import re
from pathlib import Path

# Determine optimization type (prioritize --config opt_method=... over selection.toml)
selection_path = Path(CONFIG_DIR) / "selection.toml"
OPT_METHOD = config.get("opt_method")

if not OPT_METHOD:
    try:
        with open(selection_path, "r") as f:
            content = f.read()
            match = re.search(r'optimization_type\s*=\s*"([^"]+)"', content)
            if match:
                OPT_METHOD = match.group(1)
    except Exception as e:
        print(f"Warning: Could not read {selection_path}: {e}. Defaulting to 'box'")

if not OPT_METHOD:
    OPT_METHOD = "box"

print(f"INFO: Using optimization method: {OPT_METHOD}")

# Redefine output and cache directories to be method-specific
OUTPUT_DIR = f"{ROOT_OUTPUT_DIR}/{OPT_METHOD}"
CACHE_DIR = f"{OUTPUT_DIR}/cache"

# ---------------------------------------------------------------------------
# Config file list (all TOML files in config/)
# ---------------------------------------------------------------------------
CONFIG_FILES = [
    f"{CONFIG_DIR}/{f}"
    for f in [
        "physics.toml",
        "detector.toml",
        "fitting.toml",
        "selection.toml",
        "triggers.toml",
        "data.toml",
        "efficiencies.toml",
        "paths.toml",
        "luminosity.toml",
        "branching_fractions.toml",
    ]
]

# ---------------------------------------------------------------------------
# rule all ‚ÄĒ final targets
# ---------------------------------------------------------------------------
rule all:
    input:
        expand(
            f"{OUTPUT_DIR}/{{branch}}/tables/branching_fraction_ratios.csv",
            branch=BRANCHES,
        ),
        expand(
            f"{OUTPUT_DIR}/{{branch}}/LL_DD/tables/fitted_yields_combined.csv",
            branch=BRANCHES,
        ),
        f"{OUTPUT_DIR}/comparison/branch_comparison.md",
        f"{OUTPUT_DIR}/results/bf_products.tex",
        f"{OUTPUT_DIR}/results/systematics_summary.md",

# ---------------------------------------------------------------------------
# Step 1: Config validation
# ---------------------------------------------------------------------------
rule validate_config:
    input:
        CONFIG_FILES,
    output:
        touch(f"{OUTPUT_DIR}/.config_validated"),
    params:
        config_dir=CONFIG_DIR,
        output_dir=OUTPUT_DIR,
    script:
        "scripts/validate_config.py"

# ---------------------------------------------------------------------------
# Step 2: Data/MC loading + Lambda pre-selection
# Outputs a nested dict {year: {category: array}} for data and
# {state: {category: array}} for MC, stored in the cache.
# ---------------------------------------------------------------------------
rule load_data:
    input:
        f"{OUTPUT_DIR}/.config_validated",
    output:
        touch(f"{OUTPUT_DIR}/.data_loaded"),
    params:
        years=YEARS,
        track_types=TRACK_TYPES,
        magnets=MAGNETS,
        states=STATES,
        no_cache=NO_CACHE,
        config_dir=CONFIG_DIR,
        cache_dir=CACHE_DIR,
    script:
        "scripts/load_data.py"

# ---------------------------------------------------------------------------
# Step 3: Selection optimization ‚ÄĒ one per (branch, category)
# Each category gets its own cut set. This allows LL and DD to be independently
# optimised (reference analysis finds different optimal cuts per category).
# ---------------------------------------------------------------------------
rule optimize_selection:
    input:
        f"{OUTPUT_DIR}/.data_loaded",
    output:
        f"{OUTPUT_DIR}/{{branch}}/{{category}}/models/optimized_cuts.json",
    params:
        use_manual_cuts=USE_MANUAL_CUTS,
        no_cache=NO_CACHE,
        config_dir=CONFIG_DIR,
        cache_dir=CACHE_DIR,
        output_dir=OUTPUT_DIR,
        years=YEARS,
        category="{category}",
        branch="{branch}",
        opt_method=OPT_METHOD,
    script:
        "scripts/optimize_selection.py"

# ---------------------------------------------------------------------------
# Step 4: Apply optimized cuts ‚ÄĒ one per (branch, category)
# ---------------------------------------------------------------------------
rule apply_cuts:
    input:
        data_loaded=f"{OUTPUT_DIR}/.data_loaded",
        cuts=f"{OUTPUT_DIR}/{{branch}}/{{category}}/models/optimized_cuts.json",
    output:
        summary=f"{OUTPUT_DIR}/{{branch}}/{{category}}/tables/cut_summary.json",
    params:
        branch="{branch}",
        category="{category}",
        no_cache=NO_CACHE,
        config_dir=CONFIG_DIR,
        cache_dir=CACHE_DIR,
        output_dir=OUTPUT_DIR,
        years=YEARS,
    script:
        "scripts/apply_cuts.py"

# ---------------------------------------------------------------------------
# Step 5: Mass fitting ‚ÄĒ one per (branch, category)
# ---------------------------------------------------------------------------
rule mass_fitting:
    input:
        f"{OUTPUT_DIR}/{{branch}}/{{category}}/tables/cut_summary.json",
    output:
        f"{OUTPUT_DIR}/{{branch}}/{{category}}/tables/fitted_yields.csv",
    params:
        branch="{branch}",
        category="{category}",
        no_cache=NO_CACHE,
        config_dir=CONFIG_DIR,
        cache_dir=CACHE_DIR,
        output_dir=OUTPUT_DIR,
        opt_method=OPT_METHOD,
    script:
        "scripts/mass_fitting.py"

# ---------------------------------------------------------------------------
# Step 5b: Combined LL+DD mass fit ‚ÄĒ one per branch
# Concatenates LL and DD events per year and fits the merged sample.
# Purpose: publication-quality combined plot + cross-check yields.
# Yield extraction for branching fractions uses the separate LL/DD fits above.
# ---------------------------------------------------------------------------
rule mass_fitting_combined:
    input:
        ll=f"{OUTPUT_DIR}/{{branch}}/LL/tables/cut_summary.json",
        dd=f"{OUTPUT_DIR}/{{branch}}/DD/tables/cut_summary.json",
    output:
        f"{OUTPUT_DIR}/{{branch}}/LL_DD/tables/fitted_yields_combined.csv",
    params:
        branch="{branch}",
        no_cache=NO_CACHE,
        config_dir=CONFIG_DIR,
        cache_dir=CACHE_DIR,
        output_dir=OUTPUT_DIR,
        opt_method=OPT_METHOD,
    script:
        "scripts/mass_fitting_combined.py"

# ---------------------------------------------------------------------------
# Step 6: Efficiency calculation ‚ÄĒ one per (branch, category)
# ---------------------------------------------------------------------------
rule efficiency_calculation:
    input:
        summary=f"{OUTPUT_DIR}/{{branch}}/{{category}}/tables/cut_summary.json",
        cuts=f"{OUTPUT_DIR}/{{branch}}/{{category}}/models/optimized_cuts.json",
    output:
        efficiencies=f"{OUTPUT_DIR}/{{branch}}/{{category}}/tables/efficiencies.csv",
        ratios=f"{OUTPUT_DIR}/{{branch}}/{{category}}/tables/efficiency_ratios.csv",
    params:
        branch="{branch}",
        category="{category}",
        no_cache=NO_CACHE,
        config_dir=CONFIG_DIR,
        cache_dir=CACHE_DIR,
        output_dir=OUTPUT_DIR,
    script:
        "scripts/efficiency_calculation.py"

# ---------------------------------------------------------------------------
# Step 7: Branching fraction ratios
# Takes LL and DD fitted yields and efficiency tables as inputs.
# Yields are summed across categories before computing the ratio.
# ---------------------------------------------------------------------------
rule branching_ratios:
    input:
        yields_ll=f"{OUTPUT_DIR}/{{branch}}/LL/tables/fitted_yields.csv",
        yields_dd=f"{OUTPUT_DIR}/{{branch}}/DD/tables/fitted_yields.csv",
        efficiencies_ll=f"{OUTPUT_DIR}/{{branch}}/LL/tables/efficiencies.csv",
        efficiencies_dd=f"{OUTPUT_DIR}/{{branch}}/DD/tables/efficiencies.csv",
        ratios_ll=f"{OUTPUT_DIR}/{{branch}}/LL/tables/efficiency_ratios.csv",
        ratios_dd=f"{OUTPUT_DIR}/{{branch}}/DD/tables/efficiency_ratios.csv",
    output:
        br_ratios=f"{OUTPUT_DIR}/{{branch}}/tables/branching_fraction_ratios.csv",
        final_results=f"{OUTPUT_DIR}/{{branch}}/results/final_results.md",
    params:
        branch="{branch}",
        config_dir=CONFIG_DIR,
        cache_dir=CACHE_DIR,
        output_dir=OUTPUT_DIR,
    script:
        "scripts/branching_ratios.py"

# ---------------------------------------------------------------------------
# Step 8: Branch comparison
# ---------------------------------------------------------------------------
rule compare_branches:
    input:
        high_yield=f"{OUTPUT_DIR}/high_yield/results/final_results.md",
        low_yield=f"{OUTPUT_DIR}/low_yield/results/final_results.md",
    output:
        report=f"{OUTPUT_DIR}/comparison/branch_comparison.md",
    script:
        "scripts/compare_branches.py"

# ---------------------------------------------------------------------------
# Step 9a: Fit model systematics ‚ÄĒ one job per (branch, category)
#
# Runs 5 fit variations (resolution ¬Ī2 MeV, ARGUS endpoint ¬Ī50 MeV,
# Chebyshev background alternative) and records őīN per charmonium state.
# Depends on apply_cuts because it reads the cut-filtered data from the cache.
# ---------------------------------------------------------------------------
rule fit_systematics:
    input:
        cut_summary=f"{OUTPUT_DIR}/{{branch}}/{{category}}/tables/cut_summary.json",
    output:
        "studies/fit_systematics/output/fit_systematics_{branch}_{category}.json",
    params:
        config_dir=CONFIG_DIR,
        cache_dir=CACHE_DIR,
    shell:
        """
        uv run python studies/fit_systematics/run_fit_systematics.py \
            --branch     {wildcards.branch} \
            --category   {wildcards.category} \
            --config-dir {params.config_dir} \
            --cache-dir  {params.cache_dir} \
            --output-dir studies/fit_systematics/output
        """

# ---------------------------------------------------------------------------
# Step 9b: MVA selection threshold systematic ‚ÄĒ one job per (branch, category)
#
# Shifts the BDT threshold by ¬Ī0.01 and re-fits, recording the yield change.
# Depends on apply_cuts because it re-runs the fit on the cached cut data.
# ---------------------------------------------------------------------------
rule selection_systematic:
    input:
        cut_summary=f"{OUTPUT_DIR}/{{branch}}/{{category}}/tables/cut_summary.json",
    output:
        "studies/selection_systematic/output/selection_systematics_{branch}_{category}.json",
    params:
        config_dir=CONFIG_DIR,
        cache_dir=CACHE_DIR,
    shell:
        """
        uv run python studies/selection_systematic/run_selection_systematic.py \
            --branch     {wildcards.branch} \
            --category   {wildcards.category} \
            --config-dir {params.config_dir} \
            --cache-dir  {params.cache_dir} \
            --output-dir studies/selection_systematic/output
        """

# ---------------------------------------------------------------------------
# Step 9: Aggregate systematic uncertainties
#
# Reads fit_systematics + selection_systematic JSON outputs (now produced by
# rules 9a/9b above) and aggregates into per-state systematics tables.
# ---------------------------------------------------------------------------
rule compute_systematics:
    input:
        branching_ratios=expand(
            f"{OUTPUT_DIR}/{{branch}}/tables/branching_fraction_ratios.csv",
            branch=BRANCHES,
        ),
        fit_systs=expand(
            "studies/fit_systematics/output/fit_systematics_{branch}_{category}.json",
            branch=BRANCHES,
            category=CATEGORIES,
        ),
        sel_systs=expand(
            "studies/selection_systematic/output/selection_systematics_{branch}_{category}.json",
            branch=BRANCHES,
            category=CATEGORIES,
        ),
    output:
        expand(f"{OUTPUT_DIR}/{{branch}}/tables/systematics.json", branch=BRANCHES),
        f"{OUTPUT_DIR}/results/systematics_summary.md",
    params:
        output_dir=OUTPUT_DIR,
        studies_dir="studies",
    shell:
        """
        uv run python scripts/compute_systematics.py \
            --branches     high_yield low_yield \
            --categories   LL DD \
            --output-dir   {params.output_dir} \
            --studies-dir  {params.studies_dir}
        """

# ---------------------------------------------------------------------------
# Step 10: Export final LaTeX tables
# ---------------------------------------------------------------------------
rule export_latex_results:
    input:
        high_yield=f"{OUTPUT_DIR}/high_yield/tables/branching_fraction_ratios.csv",
        low_yield=f"{OUTPUT_DIR}/low_yield/tables/branching_fraction_ratios.csv",
        systematics=f"{OUTPUT_DIR}/results/systematics_summary.md",
    output:
        report=f"{OUTPUT_DIR}/results/bf_products.tex",
    script:
        "scripts/export_latex_results.py"

# ---------------------------------------------------------------------------
# Step 11: Collect all results into a single organised folder
# Run:  snakemake collect_results
# ---------------------------------------------------------------------------
rule collect_results:
    """Gather every important output into results/ for easy review."""
    input:
        f"{OUTPUT_DIR}/results/bf_products.tex",
        f"{OUTPUT_DIR}/results/systematics_summary.md",
        f"{OUTPUT_DIR}/comparison/branch_comparison.md",
    output:
        directory(f"{ROOT_OUTPUT_DIR}/results"),
    params:
        pipeline_dir=OUTPUT_DIR,
        studies_dir="studies",
        output_dir=f"{ROOT_OUTPUT_DIR}/results",
    shell:
        """
        uv run python scripts/collect_results.py \
            --pipeline-dir {params.pipeline_dir} \
            --studies-dir  {params.studies_dir} \
            --output-dir   {params.output_dir}
        """

# ===========================================================================
# Convenience targets
# ===========================================================================
rule clean_cache:
    """Remove cached intermediate results (pickle files)."""
    shell:
        "rm -rf {CACHE_DIR}/data/*.pkl {CACHE_DIR}/metadata/*.json"

rule clean_outputs:
    """Remove output files (tables, plots, results)."""
    shell:
        "rm -rf {OUTPUT_DIR}"

rule clean_all:
    """Remove everything (cache + outputs)."""
    shell:
        "rm -rf {CACHE_DIR}/data/*.pkl {CACHE_DIR}/metadata/*.json {OUTPUT_DIR}"
