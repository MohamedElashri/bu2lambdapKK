# MVA Optimization Snakefile
#
# Phase 2 changes: separate BDT trained per Lambda category (LL and DD).
# Per-category models are saved as:
#   output/models/catboost_bdt_LL.cbm
#   output/models/catboost_bdt_DD.cbm
#
# The main pipeline's optimize_selection.py looks for catboost_bdt_{category}.cbm
# before falling back to the combined catboost_bdt.cbm.
#
# Run order:
#   snakemake tune_catboost     # optional Optuna hyperparameter tuning
#   snakemake run_mva_study     # trains LL + DD BDTs and optimises thresholds
#   snakemake run_tmva_study    # TMVA baseline (requires ROOT)
#   snakemake compare_studies   # comparison PDF (requires pdflatex)

CATEGORIES = ["LL", "DD"]

ruleorder: run_mva_study > run_mva_ll > run_mva_dd

rule all:
    input:
        expand("output/models/catboost_bdt_{category}.cbm", category=CATEGORIES),
        "mva_optimization_completed.txt"

rule tune_catboost:
    output:
        "output/models/optuna_catboost_best_params.json"
    shell:
        """
        cd mva
        uv run python tune_catboost.py
        """

rule run_mva_study:
    input:
        # Optionally depend on tuned params if they exist; not mandatory
    output:
        expand("output/models/catboost_bdt_{category}.cbm", category=CATEGORIES),
        "mva_optimization_completed.txt"
    shell:
        """
        cd mva
        uv run python main.py --category both
        """

rule run_mva_ll:
    output:
        "output/models/catboost_bdt_LL.cbm",
        "output/tables/mva_optimization_results_LL.md"
    shell:
        """
        cd mva
        uv run python main.py --category LL
        """

rule run_mva_dd:
    output:
        "output/models/catboost_bdt_DD.cbm",
        "output/tables/mva_optimization_results_DD.md"
    shell:
        """
        cd mva
        uv run python main.py --category DD
        """

rule run_tmva_study:
    output:
        "tmva_optimization_completed.txt",
        "output/tmva/tmva_summary.md"
    shell:
        """
        cd tmva
        if python -c "import ROOT; ROOT.gSystem.Load('libTMVA'); getattr(ROOT, 'TMVA')" 2>/dev/null; then
            echo "ROOT+TMVA found. Running TMVA..."
            python run_tmva.py
            touch ../tmva_optimization_completed.txt
        else
            echo "WARNING: ROOT/TMVA not available. Creating placeholder files."
            mkdir -p ../output/tmva
            touch ../output/tmva/tmva_summary.md
            touch ../tmva_optimization_completed.txt
        fi
        """

rule compare_studies:
    input:
        "mva_optimization_completed.txt",
        "tmva_optimization_completed.txt"
    output:
        "comparison/mva_vs_tmva.pdf"
    shell:
        """
        cd comparison
        python generate_slides.py
        pdflatex -interaction=nonstopmode mva_vs_tmva.tex
        pdflatex -interaction=nonstopmode mva_vs_tmva.tex
        """
