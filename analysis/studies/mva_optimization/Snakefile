# MVA Optimization Snakefile
#
# Separate BDTs are trained per Lambda category (LL and DD).
# Per-category models are saved as:
#   generated/output/studies/mva_optimization/models/catboost_bdt_LL.cbm
#   generated/output/studies/mva_optimization/models/catboost_bdt_DD.cbm
#
# The main pipeline's optimize_selection.py looks for catboost_bdt_{category}.cbm
# before falling back to the combined catboost_bdt.cbm.
#
# Run order:
#   snakemake tune_catboost     # optional Optuna hyperparameter tuning
#   snakemake run_mva_study     # trains LL + DD BDTs and optimises thresholds
#   snakemake run_tmva_study    # TMVA baseline (requires ROOT)
#   snakemake compare_studies   # comparison PDF (requires pdflatex)

CATEGORIES = ["LL", "DD"]
OUTPUT_DIR = "generated/output/studies/mva_optimization"

ruleorder: run_mva_study > run_mva_ll > run_mva_dd

rule all:
    input:
        expand(f"{OUTPUT_DIR}/models/catboost_bdt_{{category}}.cbm", category=CATEGORIES),
        f"{OUTPUT_DIR}/mva_optimization_completed.txt"

rule tune_catboost:
    output:
        f"{OUTPUT_DIR}/models/optuna_catboost_best_params.json"
    shell:
        """
        cd mva
        uv run python tune_catboost.py
        """

rule run_mva_study:
    input:
        # Optionally depend on tuned params if they exist; not mandatory
    output:
        expand(f"{OUTPUT_DIR}/models/catboost_bdt_{{category}}.cbm", category=CATEGORIES),
        f"{OUTPUT_DIR}/mva_optimization_completed.txt"
    shell:
        """
        cd mva
        uv run python main.py --category both --output-dir ../../{OUTPUT_DIR} --completion-file ../../{OUTPUT_DIR}/mva_optimization_completed.txt
        """

rule run_mva_ll:
    output:
        f"{OUTPUT_DIR}/models/catboost_bdt_LL.cbm",
        f"{OUTPUT_DIR}/tables/mva_optimization_results_LL.md"
    shell:
        """
        cd mva
        uv run python main.py --category LL --output-dir ../../{OUTPUT_DIR}
        """

rule run_mva_dd:
    output:
        f"{OUTPUT_DIR}/models/catboost_bdt_DD.cbm",
        f"{OUTPUT_DIR}/tables/mva_optimization_results_DD.md"
    shell:
        """
        cd mva
        uv run python main.py --category DD --output-dir ../../{OUTPUT_DIR}
        """

rule run_tmva_study:
    output:
        "tmva_optimization_completed.txt",
        f"{OUTPUT_DIR}/tmva/tmva_summary.md"
    shell:
        """
        cd tmva
        if python -c "import ROOT; ROOT.gSystem.Load('libTMVA'); getattr(ROOT, 'TMVA')" 2>/dev/null; then
            echo "ROOT+TMVA found. Running TMVA..."
            python run_tmva.py
            touch ../tmva_optimization_completed.txt
        else
            echo "WARNING: ROOT/TMVA not available. Creating placeholder files."
            mkdir -p ../../{OUTPUT_DIR}/tmva
            touch ../../{OUTPUT_DIR}/tmva/tmva_summary.md
            touch ../tmva_optimization_completed.txt
        fi
        """

rule compare_studies:
    input:
        "mva_optimization_completed.txt",
        "tmva_optimization_completed.txt"
    output:
        "comparison/mva_vs_tmva.pdf"
    shell:
        """
        cd comparison
        python generate_slides.py
        pdflatex -interaction=nonstopmode mva_vs_tmva.tex
        pdflatex -interaction=nonstopmode mva_vs_tmva.tex
        """
