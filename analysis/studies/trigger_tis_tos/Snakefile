# TIS/TOS Trigger Efficiency Snakefile
#
# Workflow notes:
# - Now saves results as JSON (tis_tos_results.json) in addition to the text log.
# - The JSON is consumed by efficiency_steps/Snakefile as a dependency.

import sys
from pathlib import Path

sys.path.insert(0, str(Path(workflow.basedir).parent.parent))

rule all:
    input:
        "generated/output/studies/trigger_tis_tos/tis_tos_results.json"

rule run_tis_tos:
    output:
        json = "generated/output/studies/trigger_tis_tos/tis_tos_results.json",
        txt  = "generated/output/studies/trigger_tis_tos/tis_tos_results.txt",
    shell:
        """
        uv run python studies/trigger_tis_tos/tis_tos_study.py \
            --config-dir ../../config \
            --output-dir generated/output/studies/trigger_tis_tos \
            > {output.txt}
        """
